<view class="container"><view class="nav-bar"><text data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="iconfont icon-back" bindtap="__e"></text><text class="title">账号安全</text></view><view class="security-list"><view data-event-opts="{{[['tap',[['showChangePassword',['$event']]]]]}}" class="security-item" bindtap="__e"><view class="item-info"><text class="item-title">修改密码</text><text class="item-desc">定期修改密码可以保障账号安全</text></view><text class="iconfont icon-right"></text></view></view><uni-popup class="vue-ref" vue-id="e0731dea-1" type="center" data-ref="passwordPopup" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-container"><view class="popup-title">修改密码</view><view class="form-item"><text class="label">当前密码</text><input type="password" placeholder="请输入当前密码" data-event-opts="{{[['input',[['__set_model',['$0','oldPassword','$event',[]],['passwordForm']]]]]}}" value="{{passwordForm.oldPassword}}" bindinput="__e"/></view><view class="form-item"><text class="label">新密码</text><input type="password" placeholder="请输入6位以上新密码" data-event-opts="{{[['input',[['__set_model',['$0','newPassword','$event',[]],['passwordForm']]]]]}}" value="{{passwordForm.newPassword}}" bindinput="__e"/></view><view class="form-item"><text class="label">确认密码</text><input type="password" placeholder="请再次输入新密码" data-event-opts="{{[['input',[['__set_model',['$0','confirmPassword','$event',[]],['passwordForm']]]]]}}" value="{{passwordForm.confirmPassword}}" bindinput="__e"/></view><block wx:if="{{errorMessage}}"><view class="error-message">{{errorMessage}}</view></block><view class="popup-buttons"><button data-event-opts="{{[['tap',[['cancelChangePassword',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消</button><button class="confirm-btn" disabled="{{isSubmitting}}" data-event-opts="{{[['tap',[['confirmChangePassword',['$event']]]]]}}" bindtap="__e">{{''+(isSubmitting?'提交中...':'确认修改')+''}}</button></view></view></uni-popup></view>