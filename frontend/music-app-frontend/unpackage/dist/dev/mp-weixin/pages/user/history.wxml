<view class="container"><view class="nav-bar"><view class="status-bar" style="{{(statusBarStyle)}}"></view><view class="nav-content"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn" bindtap="__e"><text class="iconfont icon-back"></text></view><view class="title">播放历史</view><view class="placeholder" style="width:60rpx;"></view></view></view><scroll-view class="history-list" style="{{(contentStyle)}}" scroll-y="{{true}}"><block wx:if="{{$root.g0>0}}"><view class="list-content"><view class="list-header"><text class="total-count">{{$root.g1+"条播放记录"}}</text></view><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view data-event-opts="{{[['tap',[['playSong',['$0'],[[['historyList','id',item.$orig.id]]]]]]]}}" class="history-item" bindtap="__e"><view class="song-info"><view class="song-name">{{item.$orig.name}}</view><view class="song-artist">{{item.$orig.artist}}</view></view><view class="history-time"><text>{{item.m0}}</text></view><view class="song-actions"><text class="iconfont icon-play"></text></view></view></block><view data-event-opts="{{[['tap',[['clearHistory',['$event']]]]]}}" class="clear-btn" bindtap="__e"><text class="iconfont icon-delete"></text><text>清空历史记录</text></view></view></block><block wx:if="{{$root.g2===0}}"><view class="empty-state"><image class="empty-image" src="/static/empty.png" mode="aspectFit"></image><view class="empty-text">暂无播放历史</view><view class="empty-tips">您还没有播放过任何歌曲</view></view></block></scroll-view></view>