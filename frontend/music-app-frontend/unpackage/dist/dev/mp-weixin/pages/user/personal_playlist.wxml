<view class="container"><view class="nav-bar"><view class="status-bar" style="{{(statusBarStyle)}}"></view><view class="nav-content"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn" bindtap="__e"><text class="iconfont icon-back"></text></view><view class="title">个性歌单</view><view class="placeholder" style="width:60rpx;"></view></view></view><view class="content"><view class="guide-text"><text class="title">选择您喜爱的音乐标签</text><text class="subtitle">至少选择3个，最多选择6个标签</text></view><view class="tags-container"><block wx:for="{{$root.l0}}" wx:for-item="tag" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['toggleTag',['$0'],[[['tags','',index]]]]]]]}}" class="{{['tag-item',tag.g0?'active':'']}}" bindtap="__e">{{''+tag.$orig+''}}</view></block></view><block wx:if="{{$root.g1>0}}"><view class="selected-tags"><text class="label">{{"已选择 ("+$root.g2+"/6):"}}</text><view class="selected-tag-list"><block wx:for="{{selectedTags}}" wx:for-item="tag" wx:for-index="index" wx:key="index"><view class="selected-tag">{{''+tag+''}}<text data-event-opts="{{[['tap',[['removeTag',['$0'],[[['selectedTags','',index]]]]]]]}}" class="remove-tag" bindtap="__e">×</text></view></block></view></view></block><view class="action-buttons"><button class="generate-btn" disabled="{{$root.g3<3}}" data-event-opts="{{[['tap',[['generatePlaylists',['$event']]]]]}}" bindtap="__e">{{''+(isGenerating?'生成中...':'生成个性歌单')+''}}</button><button data-event-opts="{{[['tap',[['resetTags',['$event']]]]]}}" class="reset-btn" bindtap="__e">重新选择</button></view><block wx:if="{{$root.g4>0}}"><view class="results-container"><view class="results-title">为您推荐的歌单</view><view class="playlist-grid"><block wx:for="{{generatedPlaylists}}" wx:for-item="playlist" wx:for-index="index" wx:key="id"><view data-event-opts="{{[['tap',[['viewPlaylist',['$0'],[[['generatedPlaylists','id',playlist.id]]]]]]]}}" class="playlist-item" bindtap="__e"><image class="playlist-cover" src="{{playlist.coverImgUrl}}" mode="aspectFill"></image><view class="playlist-name text-ellipsis">{{playlist.name}}</view><view class="playlist-info">{{playlist.trackCount+"首"}}</view></view></block></view></view></block></view></view>