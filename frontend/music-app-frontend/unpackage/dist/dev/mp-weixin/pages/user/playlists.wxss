.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 30rpx;
  background-color: #fff;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-bar .icon-back {
  font-size: 36rpx;
  color: #333;
}
.nav-bar .title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.personalized-entry {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 30rpx;
  margin: 20rpx 0;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.personalized-entry .entry-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #8e71c7, #61a0e4);
}
.personalized-entry .entry-content {
  flex: 1;
}
.personalized-entry .entry-content .entry-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}
.personalized-entry .entry-content .entry-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
}
.personalized-entry .icon-right {
  font-size: 32rpx;
  color: #999;
}
.playlist-list {
  background-color: #fff;
}
.playlist-list .playlist-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.playlist-list .playlist-item:last-child {
  border-bottom: none;
}
.playlist-list .playlist-item .playlist-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}
.playlist-list .playlist-item .playlist-info {
  flex: 1;
}
.playlist-list .playlist-item .playlist-info .playlist-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 10rpx;
}
.playlist-list .playlist-item .playlist-info .playlist-count {
  font-size: 24rpx;
  color: #999;
}
.playlist-list .playlist-item .playlist-actions {
  display: flex;
  align-items: center;
}
.playlist-list .playlist-item .playlist-actions .action-btn {
  margin: 0 12rpx;
  font-size: 36rpx;
}
.playlist-list .playlist-item .playlist-actions .icon-add {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  width: 64rpx;
  height: 64rpx;
  font-size: 38rpx;
  color: #ffffff;
  background-color: #007AFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 10rpx rgba(0, 122, 255, 0.3);
  margin-right: 16rpx;
}
.playlist-list .playlist-item .playlist-actions .icon-delete {
  color: #ff3b30;
}
.playlist-list .playlist-item .playlist-actions .icon-right {
  color: #999;
}
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
.empty-state text {
  font-size: 28rpx;
  color: #999;
}
.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 30rpx;
  height: 88rpx;
  background-color: #fff;
  border-radius: 44rpx;
}
.create-btn .icon-add {
  font-size: 32rpx;
  color: #007AFF;
  margin-right: 10rpx;
}
.create-btn text {
  font-size: 28rpx;
  color: #007AFF;
}
.popup-content {
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
}
.popup-content.song-popup {
  width: 700rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.popup-content .popup-header {
  margin-bottom: 30rpx;
}
.popup-content .popup-header .popup-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  display: block;
}
.popup-content .popup-header .popup-subtitle {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  display: block;
  margin-top: 10rpx;
}
.popup-content .search-box {
  display: flex;
  margin-bottom: 20rpx;
}
.popup-content .search-box .search-input {
  flex: 1;
  height: 80rpx;
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-right: 10rpx;
}
.popup-content .search-box .search-btn-container {
  width: 160rpx;
}
.popup-content .search-box .search-btn-container .search-btn {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
  background-color: #007AFF;
  color: #fff;
}
.popup-content .search-box .search-btn-container .search-btn .loading-text {
  display: inline-block;
  position: relative;
}
.popup-content .search-box .search-btn-container .search-btn .loading-text:after {
  content: "";
  -webkit-animation: dots 1.5s infinite;
          animation: dots 1.5s infinite;
}
@-webkit-keyframes dots {
0% {
    content: "";
}
25% {
    content: ".";
}
50% {
    content: "..";
}
75% {
    content: "...";
}
100% {
    content: "";
}
}
@keyframes dots {
0% {
    content: "";
}
25% {
    content: ".";
}
50% {
    content: "..";
}
75% {
    content: "...";
}
100% {
    content: "";
}
}
.popup-content .search-box .search-btn-container .search-btn:disabled {
  background-color: #999;
}
.popup-content .search-results {
  flex: 1;
  max-height: 400rpx;
  overflow-y: auto;
  margin-bottom: 20rpx;
}
.popup-content .search-results .result-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}
.popup-content .search-results .result-item:last-child {
  border-bottom: none;
}
.popup-content .search-results .result-item.adding {
  background-color: rgba(0, 122, 255, 0.05);
}
.popup-content .search-results .result-item .song-info {
  flex: 1;
  margin-right: 20rpx;
}
.popup-content .search-results .result-item .song-info .song-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
  font-weight: 500;
}
.popup-content .search-results .result-item .song-info .song-artist {
  font-size: 26rpx;
  color: #999;
  display: block;
}
.popup-content .search-results .result-item .song-action {
  width: 80rpx;
  text-align: center;
}
.popup-content .search-results .result-item .song-action .icon-add {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  width: 70rpx;
  height: 70rpx;
  font-size: 40rpx;
  color: #ffffff;
  background-color: #007AFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 10rpx rgba(0, 122, 255, 0.3);
  transition: all 0.2s;
}
.popup-content .search-results .result-item .song-action .icon-add:active {
  background-color: #0062cc;
  -webkit-transform: scale(0.95);
          transform: scale(0.95);
}
.popup-content .search-results .result-item .song-action .adding-text {
  font-size: 26rpx;
  color: #007AFF;
  position: relative;
  font-weight: bold;
}
.popup-content .search-results .result-item .song-action .adding-text:after {
  content: "";
  -webkit-animation: dots 1.5s infinite;
          animation: dots 1.5s infinite;
}
.popup-content .empty-search {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
.popup-content .popup-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}
.popup-content .popup-buttons button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  margin: 0 10rpx;
}
.popup-content .popup-buttons button.cancel-btn {
  background-color: #f5f5f5;
  color: #333;
}
.popup-content .popup-buttons button.confirm-btn {
  background-color: #007AFF;
  color: #fff;
}
.popup-content .popup-buttons button.confirm-btn:disabled {
  background-color: #cccccc;
  color: #ffffff;
}
.popup-content .popup-buttons button.delete-confirm-btn {
  background-color: #ff3b30;
}
.search-tip {
  display: flex;
  align-items: center;
  background-color: #f0f7ff;
  padding: 18rpx 24rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #007AFF;
}
.search-tip .icon-info {
  font-size: 32rpx;
  color: #007AFF;
  margin-right: 12rpx;
}
.search-tip text {
  font-size: 26rpx;
  color: #333;
}
