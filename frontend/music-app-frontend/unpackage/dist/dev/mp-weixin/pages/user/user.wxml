<view class="container"><view class="user-info"><image class="avatar" src="{{userInfo.avatar||'/static/default-avatar.png'}}" mode="aspectFill" data-event-opts="{{[['tap',[['changeAvatar',['$event']]]]]}}" bindtap="__e"></image><block wx:if="{{isLoggedIn}}"><view class="info"><view data-event-opts="{{[['tap',[['changeUsername',['$event']]]]]}}" class="nickname-wrapper" bindtap="__e"><text class="nickname">{{userInfo.username||'未设置用户名'}}</text><text class="iconfont icon-edit"></text></view><text class="username">{{"ID: "+(userInfo.id||'未知')}}</text></view></block><block wx:else><view class="info"><text class="nickname">未登录</text><text class="username">点击登录</text></view></block><block wx:if="{{!isLoggedIn}}"><view data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="login-btn" bindtap="__e">登录</view></block></view><block wx:if="{{isLoggedIn}}"><view class="user-stats"><view class="stat-item"><text class="count">{{stats.favorites||0}}</text><text class="label">收藏</text></view><view class="stat-item"><text class="count">{{stats.history||0}}</text><text class="label">历史</text></view><view class="stat-item"><text class="count">{{stats.playlists||0}}</text><text class="label">歌单</text></view></view></block><block wx:if="{{isLoggedIn}}"><view class="sync-status"><text class="status-text">{{"上次同步时间: "+(lastSyncTime||'从未同步')}}</text><text data-event-opts="{{[['tap',[['startManualSync',['$event']]]]]}}" class="sync-now" bindtap="__e">立即同步</text></view></block><view class="menu-list"><view data-event-opts="{{[['tap',[['showSyncDetails',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="icon iconfont icon-sync"></text><text class="title">数据同步</text><text class="arrow iconfont icon-right"></text></view><view data-event-opts="{{[['tap',[['goToFavorites',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="icon iconfont icon-star"></text><text class="title">我的收藏</text><text class="arrow iconfont icon-right"></text></view><view data-event-opts="{{[['tap',[['goToHistory',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="icon iconfont icon-clock"></text><text class="title">播放历史</text><text class="arrow iconfont icon-right"></text></view><view data-event-opts="{{[['tap',[['goToPlaylists',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="icon iconfont icon-list"></text><text class="title">我的播放列表</text><text class="arrow iconfont icon-right"></text></view><view data-event-opts="{{[['tap',[['goToSettings',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="icon iconfont icon-setting"></text><text class="title">设置</text><text class="arrow iconfont icon-right"></text></view></view><block wx:if="{{isLoggedIn}}"><view class="logout-section"><u-button vue-id="380011e0-1" type="error" data-event-opts="{{[['^click',[['handleLogout']]]]}}" bind:click="__e" bind:__l="__l" vue-slots="{{['default']}}">退出登录</u-button></view></block><uni-popup class="vue-ref" vue-id="380011e0-2" type="center" data-ref="syncPopup" bind:__l="__l" vue-slots="{{['default']}}"><view class="sync-popup"><view class="sync-popup-title">数据同步</view><view class="sync-info"><view class="sync-info-item"><text class="sync-info-label">上次同步时间:</text><text class="sync-info-value">{{lastSyncTime}}</text></view><view class="sync-info-item"><text class="sync-info-label">同步状态:</text><text class="{{['sync-info-value',syncStatusClass]}}">{{syncStatusText}}</text></view><block wx:if="{{syncError}}"><view class="sync-info-item"><text class="sync-info-label">错误信息:</text><text class="sync-info-value error">{{syncError}}</text></view></block></view><view class="sync-stats"><view class="sync-stat-item"><text class="sync-stat-count">{{syncStats.favorites}}</text><text class="sync-stat-label">收藏</text></view><view class="sync-stat-item"><text class="sync-stat-count">{{syncStats.history}}</text><text class="sync-stat-label">历史</text></view><view class="sync-stat-item"><text class="sync-stat-count">{{syncStats.playlists}}</text><text class="sync-stat-label">歌单</text></view></view><view class="sync-actions"><button class="sync-button" disabled="{{isSyncing}}" loading="{{isSyncing}}" data-event-opts="{{[['tap',[['startManualSync',['$event']]]]]}}" bindtap="__e">{{''+(isSyncing?'同步中...':'立即同步')+''}}</button></view><text data-event-opts="{{[['tap',[['closeSyncPopup',['$event']]]]]}}" class="sync-close" bindtap="__e">关闭</text></view></uni-popup></view>