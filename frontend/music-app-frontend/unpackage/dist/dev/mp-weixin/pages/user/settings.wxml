<view class="container"><view class="nav-bar"><text data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="iconfont icon-back" bindtap="__e"></text><text class="title">设置</text></view><view class="settings-list"><view class="settings-group"><view class="settings-title">账号设置</view><view data-event-opts="{{[['tap',[['goToProfile',['$event']]]]]}}" class="settings-item" bindtap="__e"><text class="item-title">个人资料</text><text class="iconfont icon-right"></text></view><view data-event-opts="{{[['tap',[['goToSecurity',['$event']]]]]}}" class="settings-item" bindtap="__e"><text class="item-title">账号安全</text><text class="iconfont icon-right"></text></view></view><view class="settings-group"><view class="settings-title">应用设置</view><view class="settings-item"><text class="item-title">自动播放</text><u-switch bind:change="__e" bind:input="__e" vue-id="d4867bf0-1" value="{{settings.autoPlay}}" data-event-opts="{{[['^change',[['saveSettings']]],['^input',[['__set_model',['$0','autoPlay','$event',[]],['settings']]]]]}}" bind:__l="__l"></u-switch></view><view class="settings-item"><text class="item-title">后台播放</text><u-switch bind:change="__e" bind:input="__e" vue-id="d4867bf0-2" value="{{settings.backgroundPlay}}" data-event-opts="{{[['^change',[['saveSettings']]],['^input',[['__set_model',['$0','backgroundPlay','$event',[]],['settings']]]]]}}" bind:__l="__l"></u-switch></view><view class="settings-item"><text class="item-title">音质选择</text><view data-event-opts="{{[['tap',[['showQualitySelector',['$event']]]]]}}" class="item-value" bindtap="__e"><text>{{qualityOptions[settings.quality]}}</text><text class="iconfont icon-right"></text></view></view><view class="settings-item"><text class="item-title">游客模式</text><view class="guest-mode-switch"><u-switch bind:change="__e" bind:input="__e" vue-id="d4867bf0-3" value="{{isGuestMode}}" data-event-opts="{{[['^change',[['toggleGuestMode']]],['^input',[['__set_model',['','isGuestMode','$event',[]]]]]]}}" bind:__l="__l"></u-switch></vie