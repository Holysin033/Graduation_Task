<view class="container"><view class="nav-bar"><text data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="iconfont icon-back" bindtap="__e"></text><text class="title">我的播放列表</text></view><view data-event-opts="{{[['tap',[['goToPersonalPlaylist',['$event']]]]]}}" class="personalized-entry" bindtap="__e"><image class="entry-img" src="/static/personalized-playlist.png" mode="aspectFill"></image><view class="entry-content"><text class="entry-title">个性歌单</text><text class="entry-desc">根据您的音乐喜好，定制专属歌单</text></view><text class="iconfont icon-right"></text></view><block wx:if="{{$root.g0>0}}"><view class="playlist-list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="playlist-item"><image class="playlist-cover" src="{{item.$orig.cover||'/static/music-cover.png'}}" mode="aspectFill"></image><view data-event-opts="{{[['tap',[['viewPlaylist',['$0'],[[['playlists','id',item.$orig.id]]]]]]]}}" class="playlist-info" bindtap="__e"><text class="playlist-name">{{item.$orig.name+'  '+''}}</text><text class="playlist-count">{{'共'+item.g1+"首歌曲"}}</text></view><view class="playlist-actions"><text data-event-opts="{{[['tap',[['openAddSongPopup',['$0'],[[['playlists','id',item.$orig.id]]]]]]]}}" class="iconfont icon-add action-btn" catchtap="__e">加</text><text data-event-opts="{{[['tap',[['deletePlaylist',['$0'],[[['playlists','id',item.$orig.id]]]]]]]}}" class="iconfont icon-delete action-btn" catchtap="__e">删</text><text data-event-opts="{{[['tap',[['viewPlaylist',['$0'],[[['playlists','id',item.$orig.id]]]]]]]}}" class="iconfont icon-right action-btn" catchtap="__e"></text></view></view></block></view></block><block wx:else><view class="empty-state"><image src="/static/empty.png" mode="aspectFit"></image><text>暂无播放列表</text></view></block><view data-event-opts="{{[['tap',[['createPlaylist',['$event']]]]]}}" class="create-btn" bindtap="__e"><text class="iconfont icon-add"></text><text>创建新播放列表</text></view><uni-popup class="vue-ref" vue-id="56592c20-1" type="center" data-ref="createPlaylistPopup" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-content"><view class="popup-title">创建播放列表</view><input class="playlist-name-input" placeholder="请输入播放列表名称" maxlength="20" data-event-opts="{{[['input',[['__set_model',['','newPlaylistName','$event',[]]]]]]}}" value="{{newPlaylistName}}" bindinput="__e"/><textarea class="playlist-desc-input" placeholder="添加描述（选填）" maxlength="200" data-event-opts="{{[['input',[['__set_model',['','newPlaylistDesc','$event',[]]]]]]}}" value="{{newPlaylistDesc}}" bindinput="__e"></textarea><view class="popup-buttons"><button data-event-opts="{{[['tap',[['cancelCreate',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消</button><button class="confirm-btn" disabled="{{!newPlaylistName}}" data-event-opts="{{[['tap',[['confirmCreate',['$event']]]]]}}" bindtap="__e">确定</button></view></view></uni-popup><uni-popup class="vue-ref" vue-id="56592c20-2" type="center" data-ref="deleteConfirmPopup" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-content"><view class="popup-title">删除播放列表</view><view class="popup-message">{{"确定要删除\""+playlistToDelete.name+"\"吗？此操作不可撤销。"}}</view><view class="popup-buttons"><button data-event-opts="{{[['tap',[['cancelDelete',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消</button><button data-event-opts="{{[['tap',[['confirmDelete',['$event']]]]]}}" class="confirm-btn delete-confirm-btn" bindtap="__e">删除</button></view></view></uni-popup><uni-popup class="vue-ref" vue-id="56592c20-3" type="center" data-ref="addSongPopup" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-content song-popup"><view class="popup-header"><text class="popup-title">添加歌曲到歌单</text><text class="popup-subtitle">{{selectedPlaylist.name}}</text></view><view class="search-box"><input class="search-input" placeholder="输入歌曲名或歌手名" focus="{{true}}" confirm-type="search" data-event-opts="{{[['confirm',[['searchSongs',['$event']]]],['input',[['__set_model',['','searchText','$event',[]]]]]]}}" value="{{searchText}}" bindconfirm="__e" bindinput="__e"/><view class="search-btn-container"><button class="search-btn" disabled="{{isSearching}}" data-event-opts="{{[['tap',[['searchSongs',['$event']]]]]}}" bindtap="__e"><block wx:if="{{isSearching}}"><text class="loading-text">搜索中...</text></block><block wx:else><text>搜索</text></block></button></view></view><block wx:if="{{$root.g2>0}}"><view><view class="search-tip"><text class="iconfont icon-info"></text><text>点击右侧<text style="color:#007AFF;font-weight:bold;">加号按钮</text>可将歌曲添加到歌单</text></view><scroll-view class="search-results" scroll-y="true"><block wx:for="{{searchResults}}" wx:for-item="song" wx:for-index="index" wx:key="id"><view class="{{['result-item',(song.isAdding)?'adding':'']}}"><view class="song-info"><text class="song-name">{{song.name}}</text><text class="song-artist">{{song.artist}}</text></view><view class="song-action"><block wx:if="{{song.isAdding}}"><text class="adding-text">添加中</text></block><block wx:else><text data-event-opts="{{[['tap',[['addSongToPlaylist',['$0'],[[['searchResults','id',song.id]]]]]]]}}" class="iconfont icon-add" bindtap="__e">+</text></block></view></view></block></scroll-view></view></block><block wx:else><block wx:if="{{hasSearched&&!isSearching}}"><view class="empty-search"><text>未找到相关歌曲</text></view></block></block><view class="popup-buttons"><button data-event-opts="{{[['tap',[['closeAddSongPopup',['$event']]]]]}}" class="cancel-btn" bindtap="__e">关闭</button><button data-event-opts="{{[['tap',[['viewSelectedPlaylist',['$event']]]]]}}" class="confirm-btn" bindtap="__e">查看歌单</button></view></view></uni-popup></view>