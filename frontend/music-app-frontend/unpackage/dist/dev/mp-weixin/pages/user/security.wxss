.container {
  min-height: 100vh;
  background-color: #f8f8f8;
}
.nav-bar {
  display: flex;
  align-items: center;
  height: 90rpx;
  background-color: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f1f1f1;
}
.nav-bar .icon-back {
  font-size: 40rpx;
  color: #333;
}
.nav-bar .title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-right: 40rpx;
}
.security-list {
  margin-top: 20rpx;
  background-color: #fff;
}
.security-list .security-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f1f1f1;
}
.security-list .security-item .item-info {
  display: flex;
  flex-direction: column;
}
.security-list .security-item .item-info .item-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 10rpx;
}
.security-list .security-item .item-info .item-desc {
  font-size: 24rpx;
  color: #999;
}
.security-list .security-item .icon-right {
  font-size: 36rpx;
  color: #999;
}
.popup-container {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 10rpx;
  width: 80vw;
}
.popup-container .popup-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}
.popup-container .form-item {
  margin-bottom: 30rpx;
}
.popup-container .form-item .label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}
.popup-container .form-item input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
.popup-container .error-message {
  color: #ff5151;
  font-size: 24rpx;
  margin-bottom: 20rpx;
  text-align: center;
}
.popup-container .popup-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}
.popup-container .popup-buttons button {
  width: 45%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 8rpx;
  border: none;
  margin: 0;
  padding: 0;
}
.popup-container .popup-buttons button.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}
.popup-container .popup-buttons button.confirm-btn {
  background-color: #1296db;
  color: #fff;
}
.popup-container .popup-buttons button.confirm-btn:disabled {
  opacity: 0.7;
}
