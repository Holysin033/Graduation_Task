<view class="container"><view class="nav-bar"><view class="status-bar" style="{{(statusBarStyle)}}"></view><view class="nav-content"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn" bindtap="__e"><text class="iconfont icon-back"></text></view><view class="title">我的收藏</view><view class="placeholder" style="width:60rpx;"></view></view></view><view data-event-opts="{{[['tap',[['goToPersonalPlaylist',['$event']]]]]}}" class="personalized-entry" bindtap="__e"><image class="entry-img" src="/static/personalized-playlist.png" mode="aspectFill"></image><view class="entry-content"><text class="entry-title">个性歌单推荐</text><text class="entry-desc">根据您的音乐喜好，定制专属歌单</text></view><text class="iconfont icon-right"></text></view><scroll-view class="favorites-list" scroll-y="{{true}}"><block wx:if="{{$root.g0>0}}"><view class="list-content"><view class="list-header"><text class="total-count">{{$root.g1+"个收藏歌单"}}</text></view><block wx:for="{{$root.l0}}" wx:for-item="playlist" wx:for-index="index" wx:key="id"><view data-event-opts="{{[['tap',[['viewPlaylist',['$0'],[[['favoritePlaylists','id',playlist.$orig.id]]]]]]]}}" class="playlist-item" bindtap="__e"><image class="cover" src="{{playlist.$orig.cover}}" mode="aspectFill"></image><view class="info"><view class="name text-ellipsis">{{playlist.$orig.name}}</view><view class="count">{{playlist.m0+"次播放"}}</view></view><view class="actions"><text data-event-opts="{{[['tap',[['removeFromFavorites',['$0'],[[['favoritePlaylists','id',playlist.$orig.id,'id']]]]]]]}}" class="iconfont icon-heart-filled" catchtap="__e"></text></view></view></block></view></block><block wx:if="{{isEmpty}}"><view class="empty-state"><image class="empty-image" src="/static/empty-favorites.png" mode="aspectFit"></image><view class="empty-text">暂无收藏内容</view><view class="empty-tips">收藏你喜欢的歌单，随时欣赏</view><view class="empty-action"><button data-event-opts="{{[['tap',[['goToPersonalPlaylist',['$event']]]]]}}" class="try-btn" bindtap="__e">尝试个性推荐</button></view></view></block></scroll-view></view>