t-scroll" scroll-y="true" lower-threshold="50" enable-back-to-top="{{true}}" scroll-anchoring="{{true}}" data-event-opts="{{[['scrolltolower',[['loadMoreArtists',['$event']]]]]}}" bindscrolltolower="__e"><view class="tab-content"><block wx:for="{{searchResults.artists}}" wx:for-item="artist" wx:for-index="index"><view data-event-opts="{{[['tap',[['viewArtist',['$0'],[[['searchResults.artists','id+index',artist.id+index]]]]]]]}}" class="artist-item" bindtap="__e"><image class="artist-avatar" src="{{artist.avatar||'/static/music-cover.png'}}" mode="aspectFill"></image><text class="artist-name">{{artist.name}}</text></view></block><block wx:if="{{$root.g3>0}}"><view class="loading-status"><block wx:if="{{isLoadingMore.artists}}"><text>正在加载更多歌手...</text></block><block wx:else><block wx:if="{{hasMore.artists}}"><text>向下滑动加载更多</text></block><block wx:else><text>已加载全部歌手</text></block></block></view></block></view></scroll-view></block><block wx:if="{{currentTab===2}}"><scroll-view class="tab-content-scroll" scroll-y="true" lower-threshold="50" enable-back-to-top="{{true}}" scroll-anchoring="{{true}}" data-event-opts="{{[['scrolltolower',[['loadMoreAlbums',['$event']]]]]}}" bindscrolltolower="__e"><view class="tab-content"><block wx:for="{{searchResults.albums}}" wx:for-item="album" wx:for-index="index"><view data-event-opts="{{[['tap',[['viewAlbum',['$0'],[[['searchResults.albums','id+index',album.id+index]]]]]]]}}" class="album-item" bindtap="__e"><image class="album-cover" src="{{album.cover||'/static/music-cover.png'}}" mode="aspectFill"></image><view class="album-info"><text class="album-name">{{album.name}}</text><text class="album-artist">{{album.artist}}</text></view></view></block><block wx:if="{{$root.g4>0}}"><view class="loading-status"><block wx:if="{{isLoadingMore.albums}}"><text>正在加载更多专辑...</text></block><block wx:else><block wx:if="{{hasMore.albums}}"><text>向下滑动加载更多</text></block><block wx:else><text>已加载全部专辑</text></block></block></view></block></view></scrol