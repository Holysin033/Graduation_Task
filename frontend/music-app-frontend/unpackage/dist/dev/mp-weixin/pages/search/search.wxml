<view class="search-container"><view class="search-bar"><view class="search-box"><u-icon vue-id="50cad900-1" name="search" size="36" color="#999" bind:__l="__l"></u-icon><input class="search-input" type="text" placeholder="搜索歌曲、歌手、专辑、歌词" confirm-type="search" data-event-opts="{{[['confirm',[['handleSearch',['$event']]]],['input',[['__set_model',['','searchText','$event',[]]],['handleInput',['$event']]]]]}}" value="{{searchText}}" bindconfirm="__e" bindinput="__e"/><block wx:if="{{searchText}}"><u-icon vue-id="50cad900-2" name="close" size="36" color="#999" data-event-opts="{{[['^click',[['clearSearch']]]]}}" bind:click="__e" bind:__l="__l"></u-icon></block></view><text data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消</text></view><block wx:if="{{$root.g0}}"><view class="search-history"><view class="history-header"><text class="title">搜索历史</text><u-icon vue-id="50cad900-3" name="trash" size="32" color="#999" data-event-opts="{{[['^click',[['clearHistory']]]]}}" bind:click="__e" bind:__l="__l"></u-icon></view><view class="history-list"><block wx:for="{{searchHistory}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['useHistoryItem',['$0'],[[['searchHistory','',index]]]]]]]}}" class="history-item" bindtap="__e"><text>{{item}}</text></view></block></view></view></block><block wx:if="{{$root.g1}}"><view class="hot-search"><view class="hot-header"><text class="title">热门搜索</text></view><view class="hot-list"><block wx:for="{{hotSearch}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['useHistoryItem',['$0'],[[['hotSearch','',index]]]]]]]}}" class="hot-item" bindtap="__e"><text>{{item}}</text></view></block></view></view></block><block wx:if="{{searchText&&hasSearched}}"><view class="search-results"><block wx:if="{{noResults}}"><view class="no-result"><text>暂无搜索结果</text></view></block><block wx:else><view class="result-tabs"><view class="tab-heade