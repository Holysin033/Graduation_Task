.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #428cac, #a9adff);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.login-container .login-box {
  width: 100%;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}
.login-container .login-box .title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 60rpx;
}
.login-container .login-box .input-group {
  margin-bottom: 40rpx;
}
.login-container .login-box .input-group input {
  width: 100%;
  height: 88rpx;
  background: #efefef;
  border-radius: 44rpx;
  padding: 0 40rpx;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}
.login-container .login-box .input-group input:last-child {
  margin-bottom: 0;
}
.login-container .login-box .login-btn {
  width: 100%;
  height: 88rpx;
  background: #007AFF;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}
.login-container .login-box .login-btn:active {
  opacity: 0.8;
}
.login-container .login-box .register-link {
  text-align: center;
  font-size: 28rpx;
  color: #007AFF;
  margin-bottom: 40rpx;
}
.login-container .login-box .register-link:active {
  opacity: 0.8;
}
.login-container .login-box .test-account {
  text-align: center;
  font-size: 24rpx;
  color: #999;
}
.login-container .login-box .test-account text {
  display: block;
  margin-bottom: 10rpx;
}
.login-container .login-box .test-account text:last-child {
  margin-bottom: 0;
}
