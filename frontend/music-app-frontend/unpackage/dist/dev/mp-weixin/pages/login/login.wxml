<view class="login-container"><view class="login-box"><view class="title">登录</view><view class="input-group"><input type="number" placeholder="请输入手机号" maxlength="11" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['form']]]]]}}" value="{{form.phone}}" bindinput="__e"/><input type="safe-password" placeholder="请输入密码" password="{{true}}" data-event-opts="{{[['input',[['__set_model',['$0','password','$event',[]],['form']]]]]}}" value="{{form.password}}" bindinput="__e"/></view><button data-event-opts="{{[['tap',[['login',['$event']]]]]}}" class="login-btn" bindtap="__e">登录</button><button data-event-opts="{{[['tap',[['enterGuestMode',['$event']]]]]}}" class="guest-btn" bindtap="__e">游客模式</button><view data-event-opts="{{[['tap',[['goToRegister',['$event']]]]]}}" class="register-link" bindtap="__e">没有账号？立即注册</view><view class="test-account"><text>测试账号：18561265910</text><text>测试密码：123456</text></view></view></view>