.rank-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 30rpx;
}
.rank-container .nav-bar {
  padding: 20rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rank-container .nav-bar .title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
.rank-container .loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200rpx;
}
.rank-container .loading-container .loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}
.rank-container .rank-scroll {
  height: calc(100vh - 80rpx);
}
.rank-container .rank-section {
  margin: 30rpx 0;
}
.rank-container .rank-section .section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}
.rank-container .rank-section .official-rank-list {
  padding: 0 20rpx;
}
.rank-container .rank-section .official-rank-list .official-rank-item {
  margin-bottom: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-cover-wrapper {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-cover-wrapper .rank-cover {
  width: 100%;
  height: 100%;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-cover-wrapper .update-time {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 6rpx 10rpx;
  background-color: rgba(0, 0, 0, 0.4);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-songs {
  flex: 1;
  padding: 12rpx 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-songs .rank-song-item {
  display: flex;
  align-items: center;
  line-height: 1.5;
  padding: 8rpx 0;
  border-radius: 8rpx;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-songs .rank-song-item:active {
  background-color: #f5f5f5;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-songs .rank-song-item .song-index {
  width: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  text-align: center;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-songs .rank-song-item .song-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  margin-right: 10rpx;
  font-weight: 500;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-songs .rank-song-item .song-artist {
  font-size: 22rpx;
  color: #999;
  max-width: 30%;
  flex-shrink: 0;
}
.rank-container .rank-section .official-rank-list .official-rank-item .rank-songs .view-more {
  text-align: right;
  font-size: 24rpx;
  color: #1296db;
  padding: 8rpx 10rpx 0;
}
.rank-container .rank-section .global-rank-list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 15rpx;
}
.rank-container .rank-section .global-rank-list .global-rank-item {
  width: calc(33.33% - 20rpx);
  margin: 0 10rpx 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.rank-container .rank-section .global-rank-list .global-rank-item .rank-cover {
  width: 100%;
  height: 210rpx;
  border-radius: 12rpx 12rpx 0 0;
}
.rank-container .rank-section .global-rank-list .global-rank-item .rank-name {
  font-size: 24rpx;
  color: #333;
  padding: 10rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.rank-container .rank-section .global-rank-list .global-rank-item .update-time {
  font-size: 20rpx;
  color: #999;
  padding: 0 10rpx 10rpx;
  text-align: center;
}
.rank-container .loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}
.rank-container .loading-more .loading-text {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #999;
}
.rank-container .text-ellipsis {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
