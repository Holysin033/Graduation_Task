<view class="personalized-container"><block wx:if="{{!isLoggedIn}}"><view class="login-prompt"><image src="/static/logo.png" mode="aspectFit"></image><text>登录后即可享受个性化推荐</text><button data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="login-btn" bindtap="__e">立即登录</button><view class="guest-features"><view data-event-opts="{{[['tap',[['goToRankPage',['$event']]]]]}}" class="feature-item" bindtap="__e"><view class="feature-icon"><u-icon vue-id="410d41fa-1" name="list" size="32" color="#ffffff" bind:__l="__l"></u-icon></view><text class="feature-name">排行榜</text></view><view data-event-opts="{{[['tap',[['goToPersonalPlaylist',['$event']]]]]}}" class="feature-item" bindtap="__e"><view class="feature-icon"><u-icon vue-id="410d41fa-2" name="star" size="32" color="#ffffff" bind:__l="__l"></u-icon></view><text class="feature-name">个性歌单</text></view></view></view></block><block wx:else><view class="recommend-content"><view class="features-section"><view data-event-opts="{{[['tap',[['goToRankPage',['$event']]]]]}}" class="feature-item" bindtap="__e"><view class="feature-icon"><u-icon vue-id="410d41fa-3" name="list" size="32" color="#ffffff" bind:__l="__l"></u-icon></view><text class="feature-name">排行榜</text></view><view data-event-opts="{{[['tap',[['goToPersonalPlaylist',['$event']]]]]}}" class="feature-item" bindtap="__e"><view class="feature-icon"><u-icon vue-id="410d41fa-4" name="star" size="32" color="#ffffff" bind:__l="__l"></u-icon></view><text class="feature-name">个性歌单</text></view></view><view class="music-player"><image class="cover-image" src="{{currentSong.cover}}" mode="aspectFill"></image><view class="song-info"><text class="song-name">{{currentSong.name}}</text><text class="artist-name">{{currentSong.artist}}</text></view><view class="player-controls"><view class="action-buttons"><button data-event-opts="{{[['tap',[['handleDislike',['$event']]]]]}}" class="dislike-btn" bindtap="__e"><image src="/static/images/dislike.png" mode="aspectFit"></image></button><button data-event-opts="{{[['tap',[['handleLike',['$event']]]]]}}" class="like-btn" bindtap="__e"><image src="/static/images/like.png" mode="aspectFit"></image></button></view><block wx:if="{{isLiked}}"><view class="next-buttons"><button data-event-opts="{{[['tap',[['playNext',['$event']]]]]}}" class="next-btn" bindtap="__e">下一首</button><button data-event-opts="{{[['tap',[['continuePlaying',['$event']]]]]}}" class="continue-btn" bindtap="__e">继续播放</button></view></block></view></view></view></block></view>