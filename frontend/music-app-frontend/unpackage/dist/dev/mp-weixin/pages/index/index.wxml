<view class="container"><view class="search-bar"><view data-event-opts="{{[['tap',[['goToSearch',['$event']]]]]}}" class="search-input" bindtap="__e"><text class="iconfont icon-search"></text><text class="placeholder">搜索音乐</text></view></view><scroll-view class="category-scroll" scroll-x="true" show-scrollbar="{{false}}"><view class="category-list"><block wx:for="{{categories}}" wx:for-item="category" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['changeCategory',['$0'],[[['categories','id',category.id,'id']]]]]]]}}" class="{{['category-item',currentCategory===category.id?'active':'']}}" bindtap="__e">{{''+category.name+''}}</view></block></view></scroll-view><view class="playlist-section"><view class="section-title">推荐歌单</view><view class="playlist-grid"><block wx:for="{{$root.l0}}" wx:for-item="playlist" wx:for-index="__i1__" wx:key="id"><view data-event-opts="{{[['tap',[['goToPlaylist',['$0'],[[['filteredPlaylists','id',playlist.$orig.id]]]]]]]}}" class="playlist-item" bindtap="__e"><image class="playlist-cover" src="{{playlist.$orig.cover}}" mode="aspectFill"></image><view class="playlist-info"><text class="playlist-name text-ellipsis">{{playlist.$orig.name}}</text><text class="playlist-count">{{playlist.m0}}</text></view><view data-event-opts="{{[['tap',[['toggleFavorite',['$0'],[[['filteredPlaylists','id',playlist.$orig.id]]]]]]]}}" class="favorite-btn" catchtap="__e"><text class="{{['iconfont',playlist.m1?'icon-star':'icon-star']}}" style="{{'color:'+(playlist.m2?'#007AFF':'#ffffff')+';'}}"></text></view></view></block></view></view></view>