.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 2rpx;
}
.container .search-bar {
  padding: 20rpx 30rpx;
  background-color: #ffffff;
}
.container .search-bar .search-input {
  display: flex;
  align-items: center;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 30rpx;
}
.container .search-bar .search-input .iconfont {
  font-size: 32rpx;
  color: #999;
  margin-right: 10rpx;
}
.container .search-bar .search-input .placeholder {
  font-size: 28rpx;
  color: #999;
}
.container .category-scroll {
  background-color: #ffffff;
  white-space: nowrap;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}
.container .category-scroll .category-list {
  padding: 0 20rpx;
  display: inline-block;
}
.container .category-scroll .category-list .category-item {
  display: inline-block;
  padding: 10rpx 30rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 28rpx;
}
.container .category-scroll .category-list .category-item.active {
  color: #ffffff;
  background-color: #007AFF;
}
.container .playlist-section {
  background-color: #ffffff;
  padding: 30rpx;
}
.container .playlist-section .section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}
.container .playlist-section .playlist-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.container .playlist-section .playlist-grid .playlist-item {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f8f8f8;
}
.container .playlist-section .playlist-grid .playlist-item .playlist-cover {
  width: 100%;
  height: 320rpx;
  border-radius: 12rpx;
}
.container .playlist-section .playlist-grid .playlist-item .playlist-info {
  padding: 16rpx;
}
.container .playlist-section .playlist-grid .playlist-item .playlist-info .playlist-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.container .playlist-section .playlist-grid .playlist-item .playlist-info .playlist-count {
  font-size: 24rpx;
  color: #999;
}
.container .playlist-section .playlist-grid .playlist-item .favorite-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 60rpx;
  height: 60rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.container .playlist-section .playlist-grid .playlist-item .favorite-btn .iconfont {
  font-size: 36rpx;
  color: #ffffff;
}
.container .playlist-section .playlist-grid .playlist-item .favorite-btn .iconfont.icon-star-filled {
  color: #007AFF;
}
.text-ellipsis {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
  display: block;
}
/* 覆盖index.scss中的样式 */
.playlist-section .playlist-grid .playlist-item .playlist-info .playlist-name {
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}
