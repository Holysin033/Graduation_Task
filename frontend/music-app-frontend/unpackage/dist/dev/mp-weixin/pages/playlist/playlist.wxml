<view class="container"><view data-event-opts="{{[['tap',[['showFullDescription',['$event']]]]]}}" class="playlist-header" bindtap="__e"><image class="cover" src="{{playlistInfo.cover||'/static/default-playlist.png'}}" mode="aspectFill"></image><view class="info"><scroll-view class="name-scroll" scroll-x="true" show-scrollbar="{{false}}" scroll-left="{{scrollLeft}}" data-event-opts="{{[['scroll',[['onScroll',['$event']]]]]}}" bindscroll="__e"><text class="name">{{playlistInfo.name}}</text></scroll-view><text class="creator">{{"创建者："+playlistInfo.creator}}</text><text class="description">{{playlistInfo.description||'暂无描述'}}</text><block wx:if="{{playlistInfo.description}}"><text class="more">点击查看完整介绍</text></block></view></view><view class="song-count-info"><text>{{"共"+totalSongs+"首歌曲，已加载"+$root.g0+"首"}}</text><block wx:if="{{isUserPlaylist}}"><view data-event-opts="{{[['tap',[['addSong',['$event']]]]]}}" class="add-song-btn" bindtap="__e"><text class="iconfont icon-add"></text><text>添加歌曲</text></view></block></view><scroll-view class="song-list-scroll" scroll-y="true" lower-threshold="50" refresher-enabled="{{true}}" refresher-triggered="{{isRefreshing}}" enable-back-to-top="{{true}}" scroll-anchoring="{{true}}" data-event-opts="{{[['scrolltolower',[['loadMoreSongs',['$event']]]],['refresherrefresh',[['onRefresh',['$event']]]]]}}" bindscrolltolower="__e" bindrefresherrefresh="__e"><view class="song-list"><block wx:if="{{isInitialLoading}}"><view class="loading-skeleton"><block wx:for="{{8}}" wx:for-item="i" wx:for-index="__i0__" wx:key="*this"><view class="skeleton-item"><view class="skeleton-index"></view><view class="skeleton-content"><view class="skeleton-name"></view><view class="skeleton-artist"></view></view><view class="skeleton-actions"></view></view></block></view></block><block wx:for="{{$root.l0}}" wx:for-item="song" wx:for-index="index"><block wx:if="{{!isInitialLoading}}"><view data-event-opts="{{[['tap',[['playSong',['$0'],[[['songs','id+\'-\'+index',song.$orig.id+'-'+index]]]]]]]}}" class="song-item" bindtap="__e"><view class="index">{{index+1}}</view><view class="song-info"><text class="name">{{song.$orig.name}}</text><text class="artist">{{song.$orig.artist}}</text></view><view class="song-actions"><block wx:if="{{isUserPlaylist}}"><text data-event-opts="{{[['tap',[['removeSong',['$0',index],[[['songs','id+\'-\'+index',song.$orig.id+'-'+index]]]]]]]}}" class="delete-btn iconfont icon-delete" catchtap="__e"></text></block><text class="duration">{{song.m0}}</text></view></view></block></block><block wx:if="{{$root.g1>0}}"><view class="loading-status"><block wx:if="{{isLoading}}"><view class="loading-more"><view class="loading-spinner"></view><text>正在加载更多歌曲...</text></view></block><block wx:else><block wx:if="{{hasMore}}"><text>向下滑动加载更多</text></block><block wx:else><text>{{"已加载全部歌曲("+$root.g2+"/"+totalSongs+")"}}</text></block></block></view></block><view class="bottom-placeholder"></view></view></scroll-view><block wx:if="{{showDescription}}"><view data-event-opts="{{[['tap',[['hideFullDescription',['$event']]]]]}}" class="description-popup" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="popup-content" catchtap="__e"><view class="popup-header"><text class="title">歌单介绍</text><text data-event-opts="{{[['tap',[['hideFullDescription',['$event']]]]]}}" class="close" bindtap="__e">×</text></view><scroll-view class="popup-body" scroll-y="true"><text class="full-description">{{playlistInfo.description}}</text></scroll-view></view></view></block><uni-popup class="vue-ref" vue-id="20b73700-1" type="bottom" data-ref="moreOptionsPopup" bind:__l="__l" vue-slots="{{['default']}}"><view class="options-menu"><view data-event-opts="{{[['tap',[['toggleFavorite',['$event']]]]]}}" class="option-item" bindtap="__e"><text class="{{['option-icon','iconfont',isFavorited?'icon-favorite-filled':'icon-favorite']}}"></text><text class="option-text">{{isFavorited?'取消收藏':'收藏'}}</text></view><view data-event-opts="{{[['tap',[['sharePlaylist',['$event']]]]]}}" class="option-item" bindtap="__e"><text class="option-icon iconfont icon-share"></text><text class="option-text">分享</text></view><block wx:if="{{isUserCreated}}"><view data-event-opts="{{[['tap',[['showDeleteConfirm',['$event']]]]]}}" class="option-item delete-option" bindtap="__e"><text class="option-icon iconfont icon-delete"></text><text class="option-text">删除歌单</text></view></block><view data-event-opts="{{[['tap',[['closeMoreOptions',['$event']]]]]}}" class="option-item" bindtap="__e"><text class="option-text">取消</text></view></view></uni-popup><uni-popup class="vue-ref" vue-id="20b73700-2" type="center" data-ref="deleteConfirmPopup" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-content"><view class="popup-title">删除歌单</view><view class="popup-message">{{"确定要删除\""+playlistInfo.name+"\"吗？此操作不可撤销。"}}</view><view class="popup-buttons"><button data-event-opts="{{[['tap',[['cancelDelete',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消</button><button data-event-opts="{{[['tap',[['confirmDelete',['$event']]]]]}}" class="confirm-btn delete-confirm-btn" bindtap="__e">删除</button></view></view></uni-popup></view>