<view class="container"><view class="bg-image" style="{{'background-image:'+('url('+(currentSong.cover||defaultCover)+')')+';'}}"></view><view class="bg-mask"></view><view class="cover-section"><image class="{{['cover',(isPlaying)?'rotating':'']}}" src="{{currentSong.cover||defaultCover}}" mode="aspectFill"></image></view><view class="song-info"><text class="name">{{currentSong.name||currentSong.title||currentSong.songName||'暂无播放'}}</text><text class="artist">{{currentSong.artist||currentSong.singer||currentSong.artistName||'未知歌手'}}</text></view><view class="lyrics-section"><block wx:for="{{displayLyrics}}" wx:for-item="line" wx:for-index="index" wx:key="index"><view class="{{['lyric-line',(index===2)?'active':'']}}"><view class="lyric-text">{{''+line.text+''}}</view></view></block></view><view class="progress-bar"><text class="time">{{$root.m0}}</text><slider class="slider" value="{{progress}}" block-size="12" activeColor="#fff" backgroundColor="rgba(255, 255, 255, 0.3)" data-event-opts="{{[['change',[['onSliderChange',['$event']]]],['changing',[['onSliderChanging',['$event']]]]]}}" bindchange="__e" bindchanging="__e"></slider><text class="time">{{$root.m1}}</text></view><view class="controls"><u-icon vue-id="02ed2720-1" name="{{playModeIcon}}" size="33" color="#fff" data-event-opts="{{[['^click',[['togglePlayMode']]]]}}" bind:click="__e" bind:__l="__l"></u-icon><u-icon vue-id="02ed2720-2" name="rewind-left" size="35" color="#fff" data-event-opts="{{[['^click',[['playPrev']]]]}}" bind:click="__e" bind:__l="__l"></u-icon><u-icon vue-id="02ed2720-3" name="{{isPlaying?'pause':'play-right'}}" size="35" color="#fff" data-event-opts="{{[['^click',[['togglePlay']]]]}}" bind:click="__e" bind:__l="__l"></u-icon><u-icon vue-id="02ed2720-4" name="rewind-right-fill" size="35" color="#fff" data-event-opts="{{[['^click',[['playNext']]]]}}" bind:click="__e" bind:__l="__l"></u-icon><u-icon vue-id="02ed2720-5" name="list" size="33" color="#fff" data-event-opts="{{[['^click',[['popupList']]]]}}" bind:click="__e" bind:__l="__l"></u-icon></view><u-popup vue-id="02ed2720-6" show="{{showPlayList}}" mode="bottom" round="{{10}}" data-event-opts="{{[['^close',[['closePlayList']]]]}}" bind:close="__e" bind:__l="__l" vue-slots="{{['default']}}"><view class="play-list-popup"><view class="popup-header"><text>当前播放列表</text><view class="header-right"><text data-event-opts="{{[['tap',[['clearPlayList',['$event']]]]]}}" class="clear-btn" bindtap="__e">清空</text><text data-event-opts="{{[['tap',[['closePlayList',['$event']]]]]}}" class="close-btn" bindtap="__e">关闭</text></view></view><scroll-view class="play-list-content" scroll-y="{{true}}"><block wx:for="{{playList}}" wx:for-item="song" wx:for-index="index"><view data-event-opts="{{[['tap',[['playSongByIndex',[index]]]]]}}" class="{{['play-list-item',(currentIndex===index)?'active':'']}}" bindtap="__e"><view class="item-content"><text class="song-name">{{song.name||song.title||song.songName||'未知歌曲'}}</text><text class="artist-name">{{song.artist||song.singer||song.artistName||'未知歌手'}}</text></view><view data-event-opts="{{[['tap',[['handleDeleteClick',[index]]]]]}}" class="delete-btn" catchtap="__e"><u-icon vue-id="{{('02ed2720-7-'+index)+','+('02ed2720-6')}}" name="trash" size="30" color="#999" bind:__l="__l"></u-icon></view></view></block></scroll-view></view></u-popup></view>