.container {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 30rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}
.container .bg-image {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-size: cover;
  background-position: center;
  -webkit-filter: blur(30px);
          filter: blur(30px);
  -webkit-transform: scale(1.2);
          transform: scale(1.2);
  z-index: 0;
}
.container .bg-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 1;
}
.container .cover-section {
  position: relative;
  z-index: 2;
  margin: 30rpx 0;
  width: 500rpx;
  height: 500rpx;
  border-radius: 250rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.4);
}
.container .cover-section .cover {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.container .cover-section .cover.rotating {
  -webkit-animation: rotate 20s linear infinite;
          animation: rotate 20s linear infinite;
  -webkit-animation-play-state: running;
          animation-play-state: running;
}
.container .cover-section .cover:not(.rotating) {
  -webkit-animation-play-state: paused;
          animation-play-state: paused;
}
.container .song-info {
  position: relative;
  z-index: 2;
  text-align: center;
  margin: 10rpx 0;
  width: 100%;
}
.container .song-info .name {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}
.container .song-info .artist {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}
.container .lyrics-section {
  position: relative;
  z-index: 2;
  flex: 1;
  width: 100%;
  height: 480rpx;
  margin: 20rpx 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.container .lyrics-section .lyric-line {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  width: 100%;
  transition: all 0.3s ease;
  overflow: hidden;
}
.container .lyrics-section .lyric-line .lyric-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 30rpx;
  transition: all 0.3s ease;
  display: inline-block;
}
.container .lyrics-section .lyric-line.active .lyric-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  color: #70a7ff;
}
.container .progress-bar {
  position: relative;
  z-index: 2;
  width: 100%;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}
.container .progress-bar .time {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  width: 90rpx;
  text-align: center;
}
.container .progress-bar .slider {
  flex: 1;
  margin: 0 20rpx;
}
.container .controls {
  position: relative;
  z-index: 2;
  width: 90%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 40rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
  border-radius: 30rpx;
  -webkit-backdrop-filter: blur(10px);
  backdrop-filter: blur(10px);
}
.container .controls .u-icon {
  margin: 0;
  padding: 15rpx;
}
.play-list-popup {
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  padding-bottom: 20rpx;
}
.play-list-popup .popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: bolder;
  margin-bottom: 30rpx;
}
.play-list-popup .popup-header .header-right {
  display: flex;
  align-items: center;
  margin-right: 8rpx;
}
.play-list-popup .popup-header .header-right .clear-btn {
  font-size: 28rpx;
  color: #999;
  margin-right: 25rpx;
}
.play-list-popup .popup-header text {
  font-size: 32rpx;
  color: #333;
}
.play-list-popup .popup-header text.iconfont {
  font-size: 40rpx;
  color: #999;
}
.play-list-popup .play-list-content {
  max-height: 50vh;
}
.play-list-popup .play-list-content .play-list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}
.play-list-popup .play-list-content .play-list-item .item-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-right: 20rpx;
  min-width: 0;
}
.play-list-popup .play-list-content .play-list-item.active .song-name {
  color: #007AFF;
}
.play-list-popup .play-list-content .play-list-item.active .artist-name {
  color: #007AFF;
}
.play-list-popup .play-list-content .play-list-item .song-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.play-list-popup .play-list-content .play-list-item .artist-name {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 0;
}
.play-list-popup .play-list-content .play-list-item .delete-btn {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}
@-webkit-keyframes rotate {
from {
    -webkit-transform: rotate(0deg);
            transform: rotate(0deg);
}
to {
    -webkit-transform: rotate(360deg);
            transform: rotate(360deg);
}
}
@keyframes rotate {
from {
    -webkit-transform: rotate(0deg);
            transform: rotate(0deg);
}
to {
    -webkit-transform: rotate(360deg);
            transform: rotate(360deg);
}
}
